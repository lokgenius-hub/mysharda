# ============================================================
#  SHARDA PALACE — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git!
# ============================================================

# ── Supabase Cloud ───────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API

# Public URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/Public key — safe for browser (read-only access via RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Service Role key — NEVER use NEXT_PUBLIC_ prefix here!
# This bypasses RLS — only used in server-side API routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# ── Session Security ─────────────────────────────────────────
# Random string of at least 32 characters
# Generate one: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
SESSION_SECRET=change_this_to_a_random_32_char_string_minimum

# ── Hotel Info (used in UI) ──────────────────────────────────
NEXT_PUBLIC_HOTEL_PHONE=7303584266
NEXT_PUBLIC_HOTEL_WHATSAPP=917303584266
NEXT_PUBLIC_HOTEL_EMAIL=info@shardapalace.in
NEXT_PUBLIC_HOTEL_ADDRESS=Mathura Road, Vrindavan, UP 281121

# ── GitHub Pages Config ──────────────────────────────────────
# Leave blank if using custom domain (e.g. www.shardapalace.in)
# Set to /repo-name if using username.github.io/repo-name
NEXT_PUBLIC_BASE_PATH=

# ── Build Mode ───────────────────────────────────────────────
# Set to "static" only for GitHub Pages build (npm run build:static)
# Leave blank for local server mode
NEXT_PUBLIC_MODE=

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── AI Chatbot (pick ONE — all are free tier) ────────────────
# Option 1: Groq (recommended — fastest, generous free tier)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# Option 2: Google Gemini (free tier — 60 req/min)
# Get key from: https://aistudio.google.com/app/apikey
# GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_KEY_HERE

# Option 3: OpenRouter (free models available)
# Get key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# ── Email Notifications ──────────────────────────────────────
# Admin email to receive enquiry notifications
ADMIN_EMAIL=info@shardapalace.in

# Resend API key (free: 100 emails/day)
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# Or use SMTP (Gmail etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
