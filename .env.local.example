# ─────────────────────────────────────────────────────────────────────────────
# Sharda Hotel & Resort — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.local.example .env.local
# 2. Fill in values from your Supabase project dashboard
#    (Settings → API in the Supabase sidebar)
# 3. NEVER commit .env.local to git  (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────

# Your project URL  — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://ydgriludptadkoqkkuwt.supabase.co

# Anon / Public key — Settings → API → Project API keys → anon public
# Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlkZ3JpbHVkcHRhZGtvcWtrdXd0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3OTcxNzksImV4cCI6MjA4ODM3MzE3OX0.IqytI56U3CQGZiqOP9A6ZLLYKgHYrfX7eCjO0T15UlY

# Service Role key — Settings → API → Project API keys → service_role
# ⚠️  SERVER ONLY — never expose to the browser.  Used by API routes only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlkZ3JpbHVkcHRhZGtvcWtrdXd0Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Mjc5NzE3OSwiZXhwIjoyMDg4MzczMTc5fQ.3gT5KGu8imd7qqnolhbQhC8gtIsBthRvlMNHwRm8I5w

# Same as NEXT_PUBLIC_SUPABASE_URL — used by server-side libs that don't have
# access to the NEXT_PUBLIC_ variant at build time.
SUPABASE_URL=https://ydgriludptadkoqkkuwt.supabase.co
# ── Site URL (optional, used by some meta/OG helpers) ─────────────────────────

# Local development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (uncomment and update when deploying)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
